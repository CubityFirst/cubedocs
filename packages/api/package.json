{
  "name": "@annex/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "pnpm exec wrangler dev --port 8787 --persist-to ../../.wrangler/state",
    "migrate": "pnpm exec wrangler d1 migrations apply cubedocs-main --local --persist-to ../../.wrangler/state",
    "build": "tsc",
    "deploy": "pnpm exec wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "lib0": "^0.2.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
