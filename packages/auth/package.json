{
  "name": "@annex/auth",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "pnpm exec wrangler dev --port 8788 --persist-to ../../.wrangler/state",
    "migrate": "pnpm exec wrangler d1 migrations apply cubedocs-auth --local --persist-to ../../.wrangler/state",
    "build": "tsc",
    "deploy": "pnpm exec wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@simplewebauthn/server": "^9.0.0",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@types/zxcvbn": "^4.4.5",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
